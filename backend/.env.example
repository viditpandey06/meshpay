PORT=4000
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# MongoDB Atlas or local MongoDB connection string.
# Example Atlas URI: mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/offline-mesh

# Redis Cloud or local Redis connection string.
# If your provider gives you TLS, use rediss://...
REDIS_URL=redis://127.0.0.1:6379

IDEMPOTENCY_TTL_SECONDS=86400
PACKET_MAX_AGE_SECONDS=86400
